#:import dp kivy.metrics.dp

MDScreenManager:

    SplashScreen:
        name: "splash_screen"

        MDFloatLayout:

            md_bg_color: 0.05, 0.05, 0.05, 1

            MDLabel:
                text: app.app_title
                halign: "center"
                font_style: "H5"
                pos_hint: {"center_x": .5, "center_y": .55}

            MDSpinner:
                size_hint: None, None
                size: dp(46), dp(46)
                pos_hint: {"center_x": .5, "center_y": .38}
                active: True

    ListScreen:
        name: "list_screen"

    PlayerScreen:
        name: "player_screen"

    FavoriteScreen:
        name: "favorite_screen"

    DeveloperScreen:
        name: "developer_screen"
        
        
<ListScreen>:

    MDBoxLayout:
        orientation: "vertical"
        padding: "10dp"
        spacing: "10dp"

        MDTopAppBar:
            title: app.app_title
            elevation: 2
            left_action_items:
                [["code-tags", lambda x: setattr(app.root, "current", "developer_screen")]]
            right_action_items:
                [["heart", lambda x: setattr(app.root, "current", "favorite_screen")]]

        MDTextField:
            hint_text: "ابحث عن أغنية..."
            mode: "rectangle"
            on_text: app.filter_songs(self.text)

        ScrollView:

            MDList:
                id: songs_container


<PlayerScreen>:

    MDBoxLayout:
        orientation: "vertical"
        padding: "16dp"
        spacing: "12dp"

        MDTopAppBar:
            title: app.current_song_title
            elevation: 2
            left_action_items:
                [["arrow-left", lambda x: setattr(app.root, "current", "list_screen")]]

        FitImage:
            source: app.current_poster
            size_hint: None, None
            size: "220dp", "220dp"
            radius: [110]
            pos_hint: {"center_x": .5}

        MDLabel:
            text: app.smart_mood_tag
            halign: "center"

        MDSlider:
            min: 0
            max: app.song_length
            value: app.song_position
            hint: False
            on_touch_up:
                if self.collide_point(*args[1].pos): app.seek_song(self.value)

        MDLabel:
            text: app.time_label
            halign: "center"

        MDBoxLayout:
            adaptive_height: True
            spacing: "15dp"
            pos_hint: {"center_x": .5}

            MDIconButton:
                icon: "shuffle"
                on_release: app.toggle_shuffle()

            MDIconButton:
                icon: "skip-previous"
                on_release: app.previous_song()

            MDIconButton:
                icon: "play-circle" if not app.is_playing else "pause-circle"
                icon_size: "56dp"
                on_release: app.toggle_play()

            MDIconButton:
                icon: "skip-next"
                on_release: app.next_song()

            MDIconButton:
                icon: "repeat"
                on_release: app.toggle_repeat()

        MDCard:
            orientation: "vertical"
            padding: "12dp"
            radius: [12, 12, 12, 12]
            md_bg_color: .10, .10, .10, 1

        ScrollView:

            MDLabel:
                text: app.current_lyrics
                halign: "center"
                adaptive_height: True
                text_size: self.width, None

        MDRaisedButton:
            text: "إضافة / إزالة من المفضلة"
            pos_hint: {"center_x": .5}
            on_release: app.toggle_favorite()


<FavoriteScreen>:

    MDBoxLayout:
        orientation: "vertical"
        padding: "10dp"
        spacing: "10dp"

        MDTopAppBar:
            title: "الأغاني المفضلة"
            elevation: 2
            left_action_items:
                [["arrow-left", lambda x: setattr(app.root, "current", "list_screen")]]

        ScrollView:

            MDList:
                id: fav_songs_container


<DeveloperScreen>:

    MDBoxLayout:
        orientation: "vertical"
        padding: "10dp"
        spacing: "10dp"

        MDTopAppBar:
            title: "About Developer"
            elevation: 2
            left_action_items:
                [["arrow-left", lambda x: setattr(app.root, "current", "list_screen")]]

        ScrollView:

            MDBoxLayout:
                orientation: "vertical"
                adaptive_height: True
                spacing: "15dp"
                padding: "15dp"

                FitImage:
                    source: "mahdi.png"
                    size_hint: None, None
                    size: "180dp", "180dp"
                    radius: [90]
                    pos_hint: {"center_x": .5}

                MDLabel:
                    text: "Mahdi Musa"
                    halign: "center"
                    font_style: "H6"

                MDLabel:
                    text: "Android & Python Developer"
                    halign: "center"

                MDRaisedButton:
                    text: "Share App"
                    pos_hint: {"center_x": .5}
                    on_release: app.share_app()
